# Copia este archivo como .env y completa los valores
# cp .env.example .env

# Cadena de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:password@localhost:5432/mi_base_de_datos?schema=public"

# Puerto donde corre el servidor (por defecto 3000)
PORT=3000
